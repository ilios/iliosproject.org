---
import Content from '../layouts/Content.astro';
import { DateTime } from 'luxon';

const jan1OfThisYear = DateTime.fromObject({ month: 1, day: 1 });
---

<style>
  img {
    width: 75%;
  }

  table {
    margin-bottom: 1rem;

    tr {
      th:nth-of-type(2),
      td:nth-of-type(2) {
        text-align: right;
      }

      th:nth-of-type(1),
      td:nth-of-type(1) {
        text-align: left;
      }
    }
  }
</style>

<Content title="Pricing" description="Information on Ilios Hosting Pricing">
  <h1>Pricing</h1>
  <p><a href="/hosting">&lt;-- Back</a></p>
  <h2>We Can Host You</h2>

  <p>Our hosting service begins for as little as **$1,000 per month**, per school.</p>

  <p>Implementation, customization, and deployment fees are separate and not included.</p>

  <p>
    If you are interested, please <a href="mailto:info@iliosproject.org">contact us</a> for further details.
  </p>
  <h3>PRICE LIST (as of {jan1OfThisYear.toLocaleString()})</h3>

  <table>
    <caption>Core Services</caption>
    <thead>
      <tr>
        <th>SYSTEM APPLICATION</th>
        <th>PRICE (annual)</th>
      </tr>
    </thead>
