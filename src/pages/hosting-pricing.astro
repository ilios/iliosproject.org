        <td>Additional Storage</td>
        <td><em>Included</em></td>
      </tr>
      <tr>
        <td>Load Balancing & failover</td>
        <td><em>Included</em></td>
      </tr>
      <tr>
        <td>Audit logs</td>
        <td><em>Included</em></td>
      </tr>
      <tr>
        <td>Multi-zone redundancy</td>
        <td><em>Included</em></td>
