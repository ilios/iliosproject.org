---
import FaIcon from './FaIcon.astro';
---

<style>
  footer {
    border-top: 1px solid var(--orange);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-between;
    margin-top: 1rem;
    padding: 1rem 1rem;

    div {
      align-items: center;
      display: inline-flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.25em 1em;
      white-space: nowrap;
    }
    .bigger-icon {
      width: 36px;
      height: 36px;
      color: var(--black);
    }
    .fa-square-rss {
      color: #d3622b;
    }
  }
</style>
<footer>
  <div>
    <span class="text">a product of</span>
    <a href="https://medschool.ucsf.edu/" target="_blank"
      ><img src="/media/ucsf-som-logo.png" alt="UCSF School of Medicine" /></a
    >
    <a href="https://www.medbiq.org/" target="_blank"
      ><img src="/media/MEDBIQ-logo.png" alt="Medbiquitous Member" /></a
    >
  </div>
  <a href="/acr" title="Universal Access, Accessibility Conformance Report">
    <FaIcon iconName="universal-access" prefix="fas" class="bigger-icon" role="presentation" />
  </a>
  <a href="/feed.xml" title="Subscribe to Ilios News">
    <FaIcon iconName="square-rss" prefix="fas" class="bigger-icon" role="presentation" />
  </a>
  <a href="https://github.com/ilios" target="_blank" title="Find our source code on GitHub.">
    <FaIcon iconName="github" prefix="fab" class="bigger-icon" role="presentation" />
  </a>
  <a href="https://www.netlify.com" target="_blank">
    <img src="https://www.netlify.com/img/global/badges/netlify-color-accent.svg" alt="Netlify" />
  </a>
</footer>
